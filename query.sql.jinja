COPY (
  WITH content_item_and_taxons AS (
    SELECT
      id,
      base_path,
      document_type,
      expanded_links,
      taxons->>'base_path' AS taxon_base_path
    FROM content_items,
        jsonb_array_elements(expanded_links->'taxons') AS taxons
    WHERE taxons->>'base_path' NOT LIKE '/world/%'
      AND document_type NOT IN ('gone', 'redirect')
  )

  SELECT
    id,
    base_path,
    title,
    details->'body' as body
  FROM
    content_items
  WHERE
    id IN (SELECT id FROM content_item_and_taxons WHERE taxon_base_path = '{{ taxon_base_path }}')
  ORDER BY
    id
) to STDOUT WITH CSV HEADER;
